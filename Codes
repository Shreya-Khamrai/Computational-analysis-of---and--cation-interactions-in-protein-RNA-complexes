# Code for mapping mol_id and chains

import os

def extract_mol_id_chain_mapping(pdb_file):
    """
    Extracts mol_id (entity ID) and chain mapping from the PDB file using COMPND records.
    Returns a dictionary mapping entity IDs to chain lists and another mapping chains to entity IDs.
    """
    mol_id_chain_map = {}  # {mol_id: [chain1, chain2, ...]}
    chain_entity_map = {}  # {chain: mol_id}
    
    with open(pdb_file, 'r') as file:
        mol_id = None
        for line in file:
            if line.startswith("COMPND"):
                line = line.strip()
                
                # Extract MOL_ID
                if "MOL_ID:" in line:
                    try:
                        mol_id = line.split("MOL_ID:")[1].strip().strip(";")
                        mol_id_chain_map[mol_id] = []
                    except IndexError:
                        print(f"⚠️ Warning: Issue parsing MOL_ID in line -> {line}")

                # Extract CHAIN and map to MOL_ID
                elif "CHAIN:" in line and mol_id:
                    try:
                        chains = [ch.strip() for ch in line.split("CHAIN:")[1].strip().strip(";").split(",")]
                        mol_id_chain_map[mol_id].extend(chains)
                        for chain in chains:
                            chain_entity_map[chain] = mol_id  # Map each chain to its entity
                    except IndexError:
                        print(f"⚠️ Warning: Issue parsing CHAIN in line -> {line}")

    # Debugging Output
    print("\n🔹 **Extracted MOL_ID to Chains Mapping:**")
    for mol, chains in mol_id_chain_map.items():
        print(f"  MOL_ID {mol}: Chains -> {', '.join(chains)}")

    print("\n🔹 **Extracted Chain to MOL_ID Mapping:**")
    for chain, mol in chain_entity_map.items():
        print(f"  Chain {chain} → MOL_ID {mol}")

    return mol_id_chain_map, chain_entity_map

# Example usage
PDB_FOLDER = "D_1"
pdb_files = [f for f in os.listdir(PDB_FOLDER) if f.endswith(".pdb")]

for pdb_file in pdb_files:
    pdb_path = os.path.join(PDB_FOLDER, pdb_file)
    print(f"\n🔹 **Parsing {pdb_file}**")
    
    mol_id_map, chain_map = extract_mol_id_chain_mapping(pdb_path)

    # Extra Debugging: Check if any chains are still unknown
    for chain, mol in chain_map.items():
        if mol == "Unknown":
            print(f"⚠️ Warning: Chain {chain} has UNKNOWN MOL_ID in {pdb_file}")

