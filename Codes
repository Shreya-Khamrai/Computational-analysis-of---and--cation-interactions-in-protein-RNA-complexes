# Total count of Interaction

import pandas as pd
import os
import glob

# Folder path containing the Excel files
folder_path = "pi-pi"

# Get all Excel files matching the required pattern
excel_files = glob.glob(os.path.join(folder_path, "pdb*_pi_interactions_*.xlsx"))

# Initialize list to store results
results = []

# Process each file
for idx, file in enumerate(excel_files, start=1):
    df = pd.read_excel(file)

    # Strip spaces and standardize column names
    df.columns = df.columns.str.strip()
    df["Chain Interaction"] = df["Chain Interaction"].str.strip().str.lower()
    df["Entity Interaction"] = df["Entity Interaction"].str.strip().str.lower()

    # Extract PDB ID from filename
    pdb_id = os.path.basename(file).split("_")[0]

    # Count interactions
    intra_count = df[(df["Chain Interaction"] == "intra-chain") & 
                     (df["Entity Interaction"] == "intra-entity")].shape[0]

    inter_count = df[((df["Chain Interaction"] == "inter-chain") & (df["Entity Interaction"] == "inter-entity")) | 
                     ((df["Chain Interaction"] == "intra-chain") & (df["Entity Interaction"] == "inter-entity"))].shape[0]

    interface_count = df[(df["Chain Interaction"] == "inter-chain") & 
                         (df["Entity Interaction"] == "inter-entity")].shape[0]

    total_count = intra_count + inter_count

    # Append results
    results.append([idx, pdb_id, intra_count, inter_count, interface_count, total_count])

# Create a DataFrame to display results in tabular format
result_df = pd.DataFrame(results, columns=["Sl. No", "PDB ID", "Intra", "Inter", "Interface", "Total"])

# Save results in Excel format
excel_output_path = os.path.join(folder_path, "interaction_counts_D.xlsx")
result_df.to_excel(excel_output_path, index=False)

# Save results in Text format
text_output_path = os.path.join(folder_path, "interaction_counts_D.txt")
with open(text_output_path, "w") as f:
    f.write(result_df.to_string(index=False))

# Print message
print(f"Results saved in:\n- {excel_output_path}\n- {text_output_path}")

# Print the table
print(result_df.to_string(index=False))

