# Code for π-π and π-cation-interactions

import os
import Bio.PDB
import pandas as pd
import numpy as np

# Interaction distance cutoffs
PI_PI_CUTOFF = (3.5, 5.0)  # π-π interaction range
PI_CATION_CUTOFF = (4.5, 6.0)  # π-Cation interaction range

# Residue classifications
AROMATIC_RESIDUES = {'PHE', 'TYR', 'TRP', 'HIS'}
CATIONIC_RESIDUES = {'LYS', 'ARG', 'HIS'}
NUCLEOTIDE_TYPES = {'A', 'U', 'G', 'C', 'DA', 'DC', 'DT', 'DG'}

# π-System atoms
PI_SYSTEM_ATOMS = {
    'PHE': ['CG', 'CD1', 'CD2', 'CE1', 'CE2', 'CZ'],
    'TYR': ['CG', 'CD1', 'CD2', 'CE1', 'CE2', 'CZ'],
    'TRP': ['CG', 'CD1', 'CD2', 'NE1', 'CE2', 'CE3', 'CZ2', 'CZ3', 'CH2'],
    'HIS': ['CG', 'ND1', 'CD2', 'CE1', 'NE2'],
    'A': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6', 'N7', 'C8', 'N9'],
    'U': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6'],
    'G': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6', 'N7', 'C8', 'N9'],  
    'C': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6'],  
    'DA': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6', 'N7', 'C8', 'N9'],
    'DT': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6'],  
    'DC': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6'],  
    'DG': ['N1', 'C2', 'N3', 'C4', 'C5', 'C6', 'N7', 'C8', 'N9'],  
    'LYS': ['NZ'],
    'ARG': ['NH1', 'NH2'],  
}

def extract_mol_id_chain_mapping(pdb_file):
    """Extracts mol_id (entity ID) and chain mapping from a PDB file."""
    mol_id_chain_map = {}
    chain_entity_map = {}

    with open(pdb_file, 'r') as file:
        mol_id = None
        for line in file:
            if line.startswith("COMPND"):
                line = line.strip()
                
                if "MOL_ID:" in line:
                    mol_id = line.split("MOL_ID:")[1].strip().strip(";")
                    mol_id_chain_map[mol_id] = []

                elif "CHAIN:" in line and mol_id:
                    chains = [ch.strip() for ch in line.split("CHAIN:")[1].strip().strip(";").split(",")]
                    mol_id_chain_map[mol_id].extend(chains)
                    for chain in chains:
                        chain_entity_map[chain] = mol_id  

    for chain in chain_entity_map:
        if chain_entity_map[chain] == "":
            chain_entity_map[chain] = "1"
    
    return mol_id_chain_map, chain_entity_map

def get_pi_atoms(residue):
    """Return a list of π-system atoms in a residue."""
    resname = residue.get_resname()
    return [atom for atom in residue if atom.get_name() in PI_SYSTEM_ATOMS.get(resname, [])]

def detect_pi_interactions(pdb_file, chain_map):
    """Detects π-π and π-cation interactions between nucleotides and amino acid residues."""
    parser = Bio.PDB.PDBParser(QUIET=True)
    structure = parser.get_structure(pdb_file[:-4], pdb_file)

    # Store residues and their π-system atoms together
    residue_atoms_map = {}

    for model in structure:
        for chain in model:
            for residue in chain:
                if residue.get_resname() in AROMATIC_RESIDUES | CATIONIC_RESIDUES | NUCLEOTIDE_TYPES:
                    pi_atoms = get_pi_atoms(residue)
                    if pi_atoms:
                        residue_atoms_map[residue] = pi_atoms

    # Flatten all atoms for NeighborSearch
    all_pi_atoms = [atom for atoms in residue_atoms_map.values() for atom in atoms]
    ns = Bio.PDB.NeighborSearch(all_pi_atoms)

    interactions = []
    seen_pairs = set()

    for res1, atoms1 in residue_atoms_map.items():
        chain1, resname1, resnum1 = res1.get_parent(), res1.get_resname(), res1.get_id()[1]
        mol_id1 = chain_map.get(chain1.get_id(), "1")

        for atom1 in atoms1:
            # Find nearby atoms using NeighborSearch
            nearby_atoms = ns.search(atom1.coord, PI_CATION_CUTOFF[1], level='A')

            for atom2 in nearby_atoms:
                res2 = atom2.get_parent()
                if res1 == res2:
                    continue  # Skip self-interactions

                chain2, resname2, resnum2 = res2.get_parent(), res2.get_resname(), res2.get_id()[1]
                mol_id2 = chain_map.get(chain2.get_id(), "1")

                pair_key = frozenset([(resname1, resnum1, chain1.get_id(), atom1.get_name()),
                                      (resname2, resnum2, chain2.get_id(), atom2.get_name())])

                if pair_key in seen_pairs:
                    continue
                seen_pairs.add(pair_key)

                # Compute minimum distance
                dist = np.linalg.norm(atom1.coord - atom2.coord)

                interaction_type = None
                if PI_PI_CUTOFF[0] <= dist <= PI_PI_CUTOFF[1]:
                    interaction_type = "π-π"
                elif PI_CATION_CUTOFF[0] <= dist <= PI_CATION_CUTOFF[1]:
                    interaction_type = "π-Cation"

                if interaction_type:
                    chain_interaction = "Intra-Chain" if chain1.get_id() == chain2.get_id() else "Inter-Chain"
                    entity_interaction = "Intra-Entity" if mol_id1 == mol_id2 else "Inter-Entity"
                    interactions.append([resname1, atom1.get_name(), chain1.get_id(), resnum1, mol_id1,
                                         resname2, atom2.get_name(), chain2.get_id(), resnum2, mol_id2,
                                         round(dist, 2), interaction_type, chain_interaction, entity_interaction])

    df = pd.DataFrame(interactions, columns=["Res1", "Atom1", "Chain1", "ResNum1", "Mol_ID1",
                                             "Res2", "Atom2", "Chain2", "ResNum2", "Mol_ID2",
                                             "Distance (Å)", "Type", "Chain Interaction", "Entity Interaction"])
    return df

# Process all PDB files in the "D_1" folder
pdb_folder = "D_1"

for pdb_filename in os.listdir(pdb_folder):
    if pdb_filename.endswith(".pdb"):
        pdb_path = os.path.join(pdb_folder, pdb_filename)
        print(f"\nProcessing {pdb_filename}...")

        # Extract mol_id to chain mapping
        mol_id_chain_map, chain_entity_map = extract_mol_id_chain_mapping(pdb_path)

        # Print chain mapping
        print("\n================================== Chain Mapping ==========================================")
        for mol_id, chains in mol_id_chain_map.items():
            print(f"Entity {mol_id}: Chains {', '.join(chains)}")

        # Detect π interactions
        interaction_df = detect_pi_interactions(pdb_path, chain_entity_map)

